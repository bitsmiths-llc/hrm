# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# react-email preview server (generated by `pnpm email`)
/.react-email/

# production
/build

# misc
.DS_Store
*.pem
graphify-out/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# supabase CLI local state — link/branch bookkeeping that the CLI rewrites on
# every `supabase link` (and on `supabase gen types`), not project source
supabase/.temp/
supabase/.branches/

# typescript
*.tsbuildinfo
next-env.d.ts

*storybook.log
storybook-static

# vendored agent-skill reference docs — synced by an external tool, not
# project source; tracking them just produces recurring formatting-only diffs
.agents/skills/
